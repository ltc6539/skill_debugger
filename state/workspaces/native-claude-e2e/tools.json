            "title": "Routing Preference"
          },
          "alternatives": {
            "default": false,
            "description": "Whether to compute alternative routes.",
            "title": "Alternatives",
            "type": "boolean"
          },
          "language": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "BCP-47 language code, e.g. en-US.",
            "title": "Language"
          },
          "units": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "METRIC or IMPERIAL.",
            "title": "Units"
          },
          "field_mask": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Response field mask, defaults to duration/distance/polyline/legs.",
            "title": "Field Mask"
          }
        },
        "required": [
          "origin",
          "destination",
          "travel_mode",
          "routing_preference",
          "alternatives",
          "language",
          "units",
          "field_mask"
        ],
        "title": "gmaps_compute_routes_args",
        "type": "object",
        "additionalProperties": false
      },
      "source": "project_catalog:google_maps"
